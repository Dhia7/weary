# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (PostgreSQL)
# Option A: Single connection string (preferred in production)
# DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DB_NAME
# DB_SSL=true

# Option B: Discrete fields
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wear_db
DB_USER=postgres
DB_PASSWORD=dhianaija123

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_secure

# Sign in with Google (same Client ID as frontend NEXT_PUBLIC_GOOGLE_CLIENT_ID)
# Setup steps: see GOOGLE_SIGNIN.md in this folder
GOOGLE_CLIENT_ID=

# Frontend URL (for CORS)
# For HTTP (default)
FRONTEND_URL=http://localhost:3000

# For HTTPS (uncomment and comment out the HTTP version above)
# FRONTEND_URL=https://localhost:3000

# For Production (Render deployment)
# Replace with your actual Vercel frontend URL
# FRONTEND_URL=https://your-frontend-app.vercel.app
# BACKEND_URL=https://your-backend-app-name.onrender.com

# Email verification (use Resend API OR SMTP — at least one in production)
# Resend: https://resend.com — free tier for transactional mail
RESEND_API_KEY=
# From address (Resend: use a verified domain, or onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=Wear <onboarding@resend.dev>
# Optional display from for SMTP too
MAIL_FROM=Wear <noreply@example.com>

# SMTP fallback (Gmail, Brevo, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password

# File Upload Configuration - Cloudinary (Required for production on Render)
# Get these from https://cloudinary.com/console (free tier available)
# Without Cloudinary, images will be stored locally and lost on server restart/redeploy
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

