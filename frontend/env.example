# Public API base (no trailing /api — AuthContext appends /auth/...)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Site URL for metadata / OG (optional)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sign in with Google — Web client ID from Google Cloud Console (same value as backend GOOGLE_CLIENT_ID)
# See backend/GOOGLE_SIGNIN.md
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
